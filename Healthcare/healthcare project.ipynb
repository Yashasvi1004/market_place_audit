   "source": [
    "def get_sqlalchemy_type(dtype):\n",
    "    if pd.api.types.is_integer_dtype(dtype):\n",
    "        return Integer()\n",
    "    elif pd.api.types.is_float_dtype(dtype):\n",
    "        return Float()\n",
    "    elif pd.api.types.is_bool_dtype(dtype):\n",
    "        return Boolean()\n",
    "    elif pd.api.types.is_datetime64_any_dtype(dtype):\n",
    "        return DateTime()\n",
    "    else:\n",
    "        return Text()\n"
   ]
